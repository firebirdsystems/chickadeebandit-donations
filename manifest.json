{
  "id": "donations",
  "name": "Let Go",
  "version": "1.1.0",
  "description": "A household decision board for deciding whether to keep, let go of, repair, or re-evaluate items.",
  "entrypoint": "index.html",
  "runtime": "static",
  "category": "family",
  "tags": ["let-go", "decluttering", "household", "decisions", "items"],
  "data_access": {
    "reads": ["family.members"],
    "writes": []
  },
  "permissions": {
    "default_audience": "everyone",
    "requires_approval": false
  },
  "storage": "db",
  "db_encryption": "off",
  "row_policies": {
    "items": {
      "kind": "owner_or_visibility",
      "member_column": "created_by",
      "visibility_column": "visibility",
      "everyone_values": ["household"],
      "write_owner_only": false,
      "delete_adult_only": true,
      "column_write_acls": {
        "status": { "writable_by": ["adult"], "actions": ["update"] },
        "decision_note": { "writable_by": ["adult"], "actions": ["update"] },
        "disposition_action": { "writable_by": ["adult"], "actions": ["update"] },
        "disposition_at": { "writable_by": ["adult"], "actions": ["update"] },
        "disposition_note": { "writable_by": ["adult"], "actions": ["update"] },
        "disposition_by": { "writable_by": ["adult"], "actions": ["update"] },
        "donation_reportable": { "writable_by": ["adult"], "actions": ["update"] },
        "reevaluate_on": { "writable_by": ["adult"], "actions": ["update"] },
        "decided_by": { "writable_by": ["adult"], "actions": ["update"] },
        "decided_at": { "writable_by": ["adult"], "actions": ["update"] }
      }
    },
    "votes": {
      "kind": "inherit_visibility",
      "parent_table": "items",
      "fk_column": "item_id",
      "writer_column": "member_id",
      "max_per_member": {
        "member_column": "member_id",
        "scope_columns": ["item_id"],
        "limit": 1
      }
    },
    "comments": {
      "kind": "inherit_visibility",
      "parent_table": "items",
      "fk_column": "item_id",
      "writer_column": "member_id"
    },
    "activity": {
      "kind": "inherit_visibility",
      "parent_table": "items",
      "fk_column": "item_id",
      "writer_column": "actor_id",
      "retain_days": { "default": 365, "timestamp_column": "created_at", "override_key": "activity_history" }
    }
  },
  "publishes": [
    "donations.item_added",
    "donations.decision_made"
  ],
  "publish_acls": {
    "donations.decision_made": { "require_role": "adult" }
  },
  "alert_on": [
    "donations.item_added",
    "donations.decision_made"
  ],
  "nav": { "label": "Let Go" },
  "widget": {
    "label": "Let Go",
    "size": "small"
  },
  "resource_limits": {
    "max_db_bytes": 52428800
  },
  "icon": "📦",
  "ai_access": {
    "allowed": true,
    "mode": "read",
    "db_exports": ["active_items", "let_go_queue", "purgeatory_items", "action_report", "donation_report"]
  }
}
